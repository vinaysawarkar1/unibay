# Production Environment Variables
# Copy to .env.local on the production EC2 server
# IMPORTANT: Never commit the actual .env.local file to git

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
# Example: postgresql://laptop_user:secure_password@db.example.com:5432/laptop_builder
DATABASE_URL=postgresql://user:password@localhost:5432/laptop_builder

# ============================================
# NEXTAUTH CONFIGURATION
# ============================================

# Generate a secure random string:
# Windows PowerShell: -join ((1..32) | ForEach-Object { [char][int](0..9 | Get-Random) }) + ((65..90) + (97..122) | Get-Random -Count 16 | ForEach-Object { [char]$_ })
# Linux/Mac: openssl rand -base64 32
NEXTAUTH_SECRET=your-very-long-random-secret-key-change-this-in-production

# Your application URL
# For EC2: http://your-ec2-ip or https://your-domain.com
NEXTAUTH_URL=https://your-domain.com

# ============================================
# ADMIN PANEL CONFIGURATION
# ============================================

# Comma-separated list of admin email addresses
# Users with these emails will have admin access to /admin
ADMIN_EMAILS=admin@example.com,manager@example.com

# ============================================
# OAUTH PROVIDERS (Optional)
# ============================================

# Google OAuth Configuration
# Get these from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-production-google-client-id
GOOGLE_CLIENT_SECRET=your-production-google-client-secret

# Microsoft OAuth Configuration (if using)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ============================================
# EMAIL CONFIGURATION
# ============================================

# Gmail SMTP settings (for OTP and notifications)
# 1. Enable 2-factor authentication on your Google account
# 2. Generate App Password at: https://myaccount.google.com/apppasswords
# 3. Use the 16-character password below

EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-character-gmail-app-password

# ============================================
# OPTIONAL CONFIGURATIONS
# ============================================

# Node environment
NODE_ENV=production

# Port for Next.js (usually managed by PM2, default: 3000)
PORT=3000

# Next.js configuration
NEXT_PUBLIC_UNIBAY_ADMIN_PIN=782291

# ============================================
# PERFORMANCE & SECURITY
# ============================================

# Enable compression
NEXT_PUBLIC_COMPRESSION_ENABLED=true

# Cache configuration
NEXT_PUBLIC_CACHE_CONTROL=public, max-age=3600, must-revalidate

# ============================================
# LOGGING & MONITORING
# ============================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# ============================================
# NOTES
# ============================================

# IMPORTANT SECURITY NOTES:
# 1. NEVER commit the actual .env.local file to git
# 2. Use strong, unique passwords for all services
# 3. Change NEXTAUTH_SECRET to a secure random value
# 4. Store sensitive data securely (AWS Secrets Manager, etc.)
# 5. Rotate credentials regularly
# 6. Use HTTPS in production (set NEXTAUTH_URL to https://)
# 7. Enable SSL/TLS with Let's Encrypt on EC2
# 8. Restrict database access to EC2 instance only
# 9. Use AWS Security Groups to limit network access
# 10. Set up automated backups for your database

# ============================================
# HOW TO SETUP ON EC2
# ============================================

# 1. SSH into your EC2 instance:
#    ssh -i your-key.pem ec2-user@your-ec2-ip
#
# 2. Navigate to your app directory:
#    cd ~/apps/laptop-builder
#
# 3. Create .env.local file:
#    nano .env.local
#
# 4. Paste this file content and update with your values
#
# 5. Save file:
#    Press Ctrl+O, Enter, Ctrl+X
#
# 6. Rebuild and restart:
#    npm run build
#    pm2 restart laptop-builder
#
# 7. Verify:
#    pm2 logs laptop-builder

# ============================================
# TESTING VALUES (Development Only)
# ============================================

# ONLY use these for local development testing:
# NEXTAUTH_SECRET=test-secret-key-do-not-use-in-production
# NEXTAUTH_URL=http://localhost:3000
# DATABASE_URL=postgresql://postgres:password@localhost:5432/test_db

# ============================================
# REFERENCE LINKS
# ============================================

# NextAuth Documentation: https://next-auth.js.org/
# Prisma Documentation: https://www.prisma.io/docs/
# Google OAuth Setup: https://developers.google.com/identity/protocols/oauth2
# Gmail App Passwords: https://support.google.com/accounts/answer/185833
# AWS Security Groups: https://docs.aws.amazon.com/AWSEC2/latest/UserGuide/ec2-security-groups.html
